# ─── VERUM SWAP BACKEND ───────────────────────────────────────────────────────
# Copie para `.env` e preencha. NUNCA commite o arquivo `.env` real.

# ─── BOOT ─────────────────────────────────────────────────────────────────────
NODE_ENV=development                   # development | test | staging | production
PORT=3001
LOG_LEVEL=debug                        # debug | info | warn | error | fatal

# ─── SOLANA RPC (OBRIGATÓRIO) ─────────────────────────────────────────────────
# URL completa com credenciais embutidas (Helius, QuickNode, Triton, etc.).
SOLANA_RPC_PRIMARY=                    # ex: https://mainnet.helius-rpc.com/?api-key=<KEY>
# Lista CSV de fallbacks usados quando primary falha (failover automático).
SOLANA_RPC_FALLBACKS=                  # ex: https://api.mainnet-beta.solana.com,https://solana-api.projectserum.com

# ─── VERUM TREASURY (OBRIGATÓRIO) ─────────────────────────────────────────────
# Endereço Base58 da treasury que recebe fees.
VERUM_TREASURY_PUBKEY=                 # 32-44 chars Base58
# Fee em basis points (200 = 2%, max 1000 = 10%).
VERUM_FEE_BPS=200

# ─── JUPITER (RECOMENDADO) ────────────────────────────────────────────────────
JUPITER_API_URL=https://api.jup.ag     # endpoint padrão; trocar só em casos específicos
JUPITER_API_KEY=                       # opcional; melhora rate limits

# ─── REDIS (OBRIGATÓRIO EM PRODUÇÃO) ──────────────────────────────────────────
# Necessário para idempotency e rate-limit multi-instância.
# Em dev pode ficar vazio (in-memory fallback).
# Aceita `rediss://default:<senha>@host:port` (Upstash) ou `redis://localhost:6379`.
REDIS_URL=

# ─── CORS (CSV de origins permitidos) ─────────────────────────────────────────
# NUNCA use `*` em produção — o env.ts rejeita no boot.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# ─── SUPABASE (OPCIONAL — necessário só pras rotas /kyc) ──────────────────────
# URL do projeto Supabase (mesma do EXPO_PUBLIC_SUPABASE_URL no app).
SUPABASE_URL=                          # ex: https://abcdefg.supabase.co
# Anon key public (mesma do EXPO_PUBLIC_SUPABASE_ANON_KEY).
SUPABASE_ANON_KEY=                     # JWT public, não service role
# Service role — bypassa RLS. SÓ pra webhook /kyc/webhook (Didit não autentica).
# Tratar como ULTRA secret. Achar em Supabase → Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=             # NUNCA expor no frontend ou commitar

# ─── DIDIT KYC (OPCIONAL — necessário só pras rotas /kyc) ─────────────────────
DIDIT_API_BASE=https://verification.didit.me
DIDIT_API_KEY=                         # X-Api-Key recebido no painel da Didit
DIDIT_WORKFLOW_ID=                     # UUID do workflow configurado
DIDIT_WEBHOOK_SECRET=                  # secret pra validar HMAC do webhook
# URL pra onde Didit redireciona após verificação. Default = deep link mobile.
# Pra web, troque (ex: https://verumcrypto.com/kyc-return).
DIDIT_CALLBACK_URL=verumwallet://kyc-callback
